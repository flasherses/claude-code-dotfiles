{
  "env": {
    // "ANTHROPIC_BASE_URL": "https://api.deepseek.com/anthropic",
    // "ANTHROPIC_AUTH_TOKEN": "<your-api-key>",
    // "ANTHROPIC_MODEL": "deepseek-v4-pro[1m]",
    // "ANTHROPIC_DEFAULT_HAIKU_MODEL": "deepseek-v4-flash",
    // "ANTHROPIC_DEFAULT_SONNET_MODEL": "deepseek-v4-pro[1m]",
    // "ANTHROPIC_DEFAULT_OPUS_MODEL": "deepseek-v4-pro[1m]",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "effortLevel": "high",
  "permissions": {
    "deny": [
      "Bash(rm -rf*)",
      "Bash(curl*|*sh*)",
      "Bash(curl*|*bash*)",
      "Bash(wget*|*sh*)",
      "Bash(git push*--force*)",
      "Bash(git push*-f*)",
      "Bash(chmod 777*)",
      "Bash(dd if=*)",
      "Bash(mkfs.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File \"__CLAUDE_HOME__\\hooks\\deny-dangerous.ps1\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File \"__CLAUDE_HOME__\\hooks\\audit-edit.ps1\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File \"__CLAUDE_HOME__\\hooks\\mask-pii.ps1\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File \"__CLAUDE_HOME__\\hooks\\check-uncommitted.ps1\""
          }
        ]
      }
    ]
  }
}
